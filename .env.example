# RTMS 환경 변수 — 이 파일을 .env 로 복사 후 값 수정
# cp .env.example .env

# 필수: 세션 보안 키 (임의의 긴 문자열)
SECRET_KEY=your-secret-key-here-change-this

# 데이터베이스 (Render 배포 시 자동 주입됨)
# 로컬 개발: 생략 시 sqlite:///data.db 사용
# DATABASE_URL=postgresql://user:pass@host:5432/rtms

# 서버 포트 (로컬 개발용)
FLASK_PORT=5001

# ── 이메일 발송 설정 (SMTP) ──────────────────────────────────
# Gmail 사용 시: MAIL_SERVER=smtp.gmail.com, MAIL_PORT=587
# 네이버 사용 시: MAIL_SERVER=smtp.naver.com, MAIL_PORT=587
# 사내 메일 서버: MAIL_SERVER=mail.intops.co.kr, MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=발신자이메일@gmail.com
MAIL_PASSWORD=앱비밀번호(16자리)

# 품질팀 수신 이메일 (의뢰 접수 알림)
QA_EMAIL=igm550@intops.co.kr
